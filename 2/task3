db.dealers.aggregate([
  {
    $lookup: {
      from: "sales",          
      localField: "name",     
      foreignField: "owner",  
      as: "cars"              
    }
  },
  {
    $project: {
      _id: 1,
      average_auction_score: { $avg: "$cars.auction_evaluation" }
    }
  },
  {
    $merge: {
  into: 'dealers',
  on: '_id',
  whenMatched: 'merge'
}
  }
]);